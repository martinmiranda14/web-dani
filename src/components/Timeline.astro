---
import { getCollection } from 'astro:content';
import { t } from '../i18n/ui';

const entries = await getCollection('trayectoria');
const esEntries = entries.filter(e => e.data.lang === 'es').sort((a, b) => a.data.order - b.data.order);
const enEntries = entries.filter(e => e.data.lang === 'en').sort((a, b) => a.data.order - b.data.order);
---
<section id="trayectoria">
  <p class="section-label reveal">
    <span class="lang-es">{t('es', 'tray.label')}</span>
    <span class="lang-en">{t('en', 'tray.label')}</span>
  </p>
  <div class="timeline lang-es">
    {esEntries.map(({ data }) => (
      <div class="timeline-item reveal">
        <div class="timeline-year">{data.year}</div>
        <div class="timeline-content">
          <h3>{data.title}</h3>
          <p>{data.desc}</p>
        </div>
      </div>
    ))}
  </div>
  <div class="timeline lang-en">
    {enEntries.map(({ data }) => (
      <div class="timeline-item reveal">
        <div class="timeline-year">{data.year}</div>
        <div class="timeline-content">
          <h3>{data.title}</h3>
          <p>{data.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>
