---
import { getCollection } from 'astro:content';
import { t } from '../i18n/ui';

const entries = await getCollection('alimapu');
const es = entries.find(e => e.data.lang === 'es')?.data;
const en = entries.find(e => e.data.lang === 'en')?.data;
---
<section id="alimapu">
  <div class="alimapu-inner">
    <p class="section-label reveal">
      <span class="lang-es">{t('es', 'alimapu.label')}</span>
      <span class="lang-en">{t('en', 'alimapu.label')}</span>
    </p>
    <h2 class="reveal">Alimapu</h2>
    <h3 class="reveal">
      <span class="lang-es">{es?.subtitle}</span>
      <span class="lang-en">{en?.subtitle}</span>
    </h3>
    <p class="reveal">
      <span class="lang-es">{es?.p1}</span>
      <span class="lang-en">{en?.p1}</span>
    </p>
    <p class="reveal">
      <span class="lang-es">{es?.p2}</span>
      <span class="lang-en">{en?.p2}</span>
    </p>
    <p class="reveal">
      <span class="lang-es">{es?.p3}</span>
      <span class="lang-en">{en?.p3}</span>
    </p>
    <div class="stats-row">
      {es?.stats.map((stat, i) => (
        <div class="stat reveal">
          <h4>{stat.value}</h4>
          <p>
            <span class="lang-es" set:html={stat.label} />
            <span class="lang-en" set:html={en?.stats[i]?.label} />
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
