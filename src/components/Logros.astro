---
import { getCollection } from 'astro:content';
import { t } from '../i18n/ui';

const entries = await getCollection('logros');
const esEntries = entries.filter(e => e.data.lang === 'es').sort((a, b) => a.data.order - b.data.order);
const enEntries = entries.filter(e => e.data.lang === 'en').sort((a, b) => a.data.order - b.data.order);
---
<section id="logros">
  <h2 class="logros-heading reveal">
    <span class="lang-es" set:html={t('es', 'logros.heading')} />
    <span class="lang-en" set:html={t('en', 'logros.heading')} />
  </h2>
  <div class="logros-grid lang-es">
    {esEntries.map(({ data }) => (
      <div class="logro-card reveal">
        <span class="logro-year-tag">{data.tag}</span>
        <span class="logro-icon">{data.icon}</span>
        <h3>{data.title}</h3>
        <p>{data.desc}</p>
      </div>
    ))}
  </div>
  <div class="logros-grid lang-en">
    {enEntries.map(({ data }) => (
      <div class="logro-card reveal">
        <span class="logro-year-tag">{data.tag}</span>
        <span class="logro-icon">{data.icon}</span>
        <h3>{data.title}</h3>
        <p>{data.desc}</p>
      </div>
    ))}
  </div>
</section>
