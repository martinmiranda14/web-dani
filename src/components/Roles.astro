---
import { getCollection } from 'astro:content';
import { t } from '../i18n/ui';

const entries = await getCollection('roles');
const esEntries = entries.filter(e => e.data.lang === 'es').sort((a, b) => a.data.order - b.data.order);
const enEntries = entries.filter(e => e.data.lang === 'en').sort((a, b) => a.data.order - b.data.order);
---
<section id="roles">
  <div class="roles-header">
    <p class="section-label reveal">
      <span class="lang-es">{t('es', 'roles.label')}</span>
      <span class="lang-en">{t('en', 'roles.label')}</span>
    </p>
    <h2 class="reveal">
      <span class="lang-es" set:html={t('es', 'roles.heading')} />
      <span class="lang-en" set:html={t('en', 'roles.heading')} />
    </h2>
  </div>
  <div class="roles-grid lang-es">
    {esEntries.map(({ data }) => (
      <div class="role-category reveal">
        <div class="role-category-icon">{data.icon}</div>
        <h3>{data.title}</h3>
        <ul>
          {data.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="roles-grid lang-en">
    {enEntries.map(({ data }) => (
      <div class="role-category reveal">
        <div class="role-category-icon">{data.icon}</div>
        <h3>{data.title}</h3>
        <ul>
          {data.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
