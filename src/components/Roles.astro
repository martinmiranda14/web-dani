---
import { getCollection } from 'astro:content';
import { t } from '../i18n/ui';

const entries = await getCollection('roles');
const sorted = entries.sort((a, b) => a.data.order - b.data.order);
---
<section id="roles">
  <div class="roles-header">
    <p class="section-label reveal">
      <span class="lang-es">{t('es', 'roles.label')}</span>
      <span class="lang-en">{t('en', 'roles.label')}</span>
    </p>
    <h2 class="reveal">
      <span class="lang-es" set:html={t('es', 'roles.heading')} />
      <span class="lang-en" set:html={t('en', 'roles.heading')} />
    </h2>
  </div>
  <div class="roles-grid">
    {sorted.map(({ data }) => (
      <div class="role-category reveal">
        <div class="role-category-icon">{data.icon}</div>
        <h3>
          <span class="lang-es">{data.title_es}</span>
          <span class="lang-en">{data.title_en}</span>
        </h3>
        <ul>
          {data.items_es.map((item, i) => (
            <li>
              <span class="lang-es">{item}</span>
              <span class="lang-en">{data.items_en[i]}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
